/platbor.yaml
/platbor.local.yaml

# Go
*.test
*.out
/coverage.out

# Frontend build output — everything under web/dist is generated by
# `npm run build`, except the committed placeholder index.html that lets the Go
# build succeed before the SPA has been built.
/web/dist/*
!/web/dist/index.html

# Node
/web/node_modules/
/web/*.local

